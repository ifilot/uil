#include <winver.h>

IDI_ICON1 ICON "@UIL_WINDOWS_ICON_FILE@"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @UIL_WINDOWS_FILE_VERSION@
 PRODUCTVERSION @UIL_WINDOWS_FILE_VERSION@
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "@UIL_APP_AUTHOR@\0"
            VALUE "FileDescription", "uil PDF presentation app\0"
            VALUE "FileVersion", "@PROJECT_VERSION@\0"
            VALUE "InternalName", "uil\0"
            VALUE "LegalCopyright", "@UIL_APP_COPYRIGHT@\0"
            VALUE "OriginalFilename", "uil.exe\0"
            VALUE "ProductName", "uil\0"
            VALUE "ProductVersion", "@PROJECT_VERSION@\0"
            VALUE "Comments", "@UIL_APP_LICENSE@ - @UIL_REPOSITORY_URL@\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
